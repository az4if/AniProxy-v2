# ── Server ────────────────────────────────────────────────────────────────────
# Port used by `vercel dev` (or any local Node server). Vercel ignores this
# in production – port binding is managed by the platform.
PORT=3000

# ── AniList API ───────────────────────────────────────────────────────────────
# Upstream GraphQL endpoint. Change only if AniList ever moves their API.
ANILIST_API_URL=https://graphql.anilist.co/

# ── Upstash Redis (caching) ───────────────────────────────────────────────────
# Create a free Redis database at https://console.upstash.com
# Copy the REST URL and token from the database dashboard.
UPSTASH_REDIS_REST_URL=https://<your-database-name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>

# ── Cache TTL ─────────────────────────────────────────────────────────────────
# How long (in seconds) anonymous query responses are kept in Redis.
# Default: 300 (5 minutes). Increase for less volatile data (e.g. 3600 = 1 hr).
# Mutations and authenticated requests are never cached regardless of this value.
CACHE_TTL_SECONDS=300

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to expose X-Rate-Limit-Used on every response.
DEBUG=false
